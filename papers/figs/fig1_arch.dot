digraph architecture {
    graph [
        rankdir=TB,
        fontname="Helvetica",
        fontsize=11,
        bgcolor="white",
        pad=0.3,
        nodesep=0.55,
        ranksep=0.65,
        splines=ortho
    ]
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, penwidth=1.5]
    edge [fontname="Helvetica", fontsize=9, penwidth=1.4]

    /* ── Input pipeline ─────────────────────────────── */
    subgraph cluster_input {
        label="Speech Interface"
        style="dashed,rounded"
        color="#4A90D9"
        fontcolor="#1a4f80"
        fontsize=10
        fillcolor="#EBF4FF"

        mic  [label="Microphone\nInput",         fillcolor="#DBEAFE", color="#2563EB"]
        stt  [label="STT\nWhisper / Google",     fillcolor="#DBEAFE", color="#2563EB"]
        tts  [label="TTS\nPAL Server",           fillcolor="#DBEAFE", color="#2563EB"]
        spk  [label="Robot\nSpeaker",            fillcolor="#DBEAFE", color="#2563EB"]
    }

    /* ── Core reasoning ─────────────────────────────── */
    subgraph cluster_vlm {
        label="Core Reasoning"
        style="dashed,rounded"
        color="#7C3AED"
        fontcolor="#4C1D95"
        fontsize=10
        fillcolor="#F5F3FF"

        vlm  [label="VLMReasoner\nGemini 2.0 Flash\nplan · detect · verify",
              fillcolor="#EDE9FE", color="#7C3AED", fontsize=10, width=2.2]
    }

    /* ── Perception ─────────────────────────────────── */
    subgraph cluster_percept {
        label="Perception"
        style="dashed,rounded"
        color="#0F766E"
        fontcolor="#134e4a"
        fontsize=10
        fillcolor="#F0FDF4"

        cam  [label="Xtion RGBD\n640×480  RGB+Depth", fillcolor="#DCFCE7", color="#16A34A"]
        pm   [label="PerceptionManager\nget_latest_rgb()\nget_latest_depth()", fillcolor="#DCFCE7", color="#16A34A"]
    }

    /* ── State & Identity ───────────────────────────── */
    subgraph cluster_state {
        label="State & Identity"
        style="dashed,rounded"
        color="#B45309"
        fontcolor="#78350F"
        fontsize=10
        fillcolor="#FFFBEB"

        sm   [label="StateManager\nscene_graph · object_memory\ngripper · location · history",
              fillcolor="#FEF3C7", color="#D97706", width=2.3]
        fm   [label="FaceManager\nHTTP :5002\n128-d dlib embeddings",
              fillcolor="#FEF3C7", color="#D97706"]
    }

    /* ── Safety ─────────────────────────────────────── */
    subgraph cluster_safety {
        label="Safety"
        style="dashed,rounded"
        color="#BE123C"
        fontcolor="#881337"
        fontsize=10
        fillcolor="#FFF1F2"

        safe [label="Safety Monitor\nconsec. failures ≤ 3\nsafe-mode reset",
              fillcolor="#FFE4E6", color="#E11D48"]
    }

    /* ── Skill Library ──────────────────────────────── */
    subgraph cluster_skills {
        label="Skill Library  (BaseSkill: check_affordance · execute · verify)"
        style="dashed,rounded"
        color="#166534"
        fontcolor="#14532d"
        fontsize=10
        fillcolor="#F0FDF4"

        search [label="search_with_head\n12 pan/tilt positions\nface-visibility check",   fillcolor="#BBF7D0", color="#16A34A"]
        grab   [label="grab_bottle\nreach_object_v5\n3-min timeout",                       fillcolor="#BBF7D0", color="#16A34A"]
        handov [label="handover_to_person\n3D projection · arm ext.\ngripper open",        fillcolor="#BBF7D0", color="#16A34A"]
        misc   [label="go_home · wave\nopen_hand · close_hand\nplay_motion",               fillcolor="#D1FAE5", color="#059669"]
    }

    /* ── Grasp sub-pipeline ─────────────────────────── */
    subgraph cluster_grasp {
        label="Grasp Sub-pipeline"
        style="dashed,rounded"
        color="#1D4ED8"
        fontcolor="#1e3a8a"
        fontsize=10
        fillcolor="#EFF6FF"

        refine [label="Depth BBox\nRefinement\n10th-pct depth",  fillcolor="#BFDBFE", color="#2563EB"]
        ransac [label="RANSAC\nCylinder Fit\nr∈[0.01,0.25]m",   fillcolor="#BFDBFE", color="#2563EB"]
        moveit [label="MoveIt\narm_torso OMPL\nTorso Descent",   fillcolor="#BFDBFE", color="#2563EB"]
    }

    /* ── Edges ──────────────────────────────────────── */
    mic  -> stt  [label=" audio",  color="#2563EB"]
    stt  -> vlm  [label=" command text", color="#2563EB"]
    vlm  -> tts  [label=" response", color="#2563EB"]
    tts  -> spk  [color="#2563EB"]

    cam  -> pm   [color="#16A34A"]
    pm   -> vlm  [label=" RGB image", color="#7C3AED"]
    pm   -> sm   [label=" detections", color="#D97706", style=dashed]

    vlm  -> sm   [label=" detections", color="#D97706"]
    sm   -> vlm  [label=" context", color="#7C3AED", style=dashed, constraint=false]
    fm   -> sm   [label=" identity", color="#D97706"]
    pm   -> fm   [label=" RGB frames", color="#D97706", style=dashed]

    vlm  -> search [label=" skill select", color="#16A34A"]
    vlm  -> grab   [color="#16A34A"]
    vlm  -> handov [color="#16A34A"]
    vlm  -> misc   [color="#16A34A"]

    grab -> refine [color="#2563EB"]
    refine -> ransac [color="#2563EB"]
    ransac -> moveit [color="#2563EB"]

    vlm  -> safe   [label=" fail count", color="#E11D48", style=dashed, constraint=false]
    safe -> vlm    [label=" block", color="#E11D48", style=dashed, constraint=false]
}
