# ─────────────────────────────────────────────────────────────────────────────
# TIAGo Embodied Agent — Environment Variables
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Eden AI API key — used for Gemini 2.0 Flash VLM (object detection + reasoning)
# Sign up free at: https://www.edenai.run
EDENAI_API_KEY=your_edenai_api_key_here

# Groq API key — used for fast LLM reasoning (llama-3.3-70b)
# Sign up free at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
